---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

function getReadingTime(body: string): string {
  const words = body.split(/\s+/).length;
  const minutes = Math.ceil(words / 200);
  return `${minutes} min de leitura`;
}

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Allan Lobo',
  url: 'https://allanlobo.com',
  jobTitle: 'Desenvolvedor de Software',
  worksFor: { '@type': 'Organization', name: 'Luizalabs' },
  sameAs: ['https://www.linkedin.com/in/allanplobo/'],
});
---

<BaseLayout
  title="Home"
  description="Allan Lobo — Desenvolvedor de Software na Luizalabs. Blog sobre tecnologia, carreira e desenvolvimento."
>
  <script type="application/ld+json" set:html={jsonLd} />

  <Hero />

  <!-- Recent Posts Section -->
  <section class="recent-posts" id="recent-posts">
    <div class="recent-posts__container container">
      <div class="recent-posts__header reveal">
        <h2 class="recent-posts__title">
          Últimos do <span class="recent-posts__accent">blog</span>
        </h2>
        <a href="/blog" class="recent-posts__view-all">
          Ver todos
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="recent-posts__grid reveal-stagger">
        {allPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            readingTime={getReadingTime(post.body || '')}
            slug={post.id}
          />
        ))}
      </div>
      {allPosts.length === 0 && (
        <div class="recent-posts__empty reveal">
          <p>Nenhum post ainda. Em breve teremos conteúdo por aqui! 🚀</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
.recent-posts{padding:var(--space-16) 0}
.recent-posts__container{max-width:900px}
.recent-posts__header{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-8)}
.recent-posts__title{font-size:var(--text-2xl);font-weight:700}
.recent-posts__accent{color:var(--accent)}
.recent-posts__view-all{display:inline-flex;align-items:center;gap:var(--space-2);font-size:var(--text-sm);color:var(--text-muted);font-weight:500;text-decoration:none;transition:all var(--duration-normal) var(--ease-out)}
.recent-posts__view-all:hover{color:var(--accent)}
.recent-posts__view-all:hover svg{transform:translateX(4px)}
.recent-posts__view-all svg{transition:transform var(--duration-normal) var(--ease-out)}
.recent-posts__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(380px,1fr));gap:var(--space-6)}
.recent-posts__empty{text-align:center;padding:var(--space-12);color:var(--text-muted)}
@media(max-width:768px){
  .recent-posts__grid{grid-template-columns:1fr}
  .recent-posts__header{flex-direction:column;align-items:flex-start;gap:var(--space-2)}
}
</style>
