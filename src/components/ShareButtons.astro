---
import { type Lang, defaultLang, useTranslations } from "../i18n/i18n";

interface Props {
  url: string;
  title: string;
  lang?: Lang;
}
const { url, lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const fullUrl = new URL(url, Astro.site).toString();
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(fullUrl)}`;
---

<div class="share-buttons">
  <span class="share-buttons__label">{t("post.share")}</span>
  <div class="share-buttons__list">
    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="share-buttons__btn"
      aria-label="LinkedIn"
      title="LinkedIn"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path
          d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
        ></path><rect width="4" height="12" x="2" y="9"></rect><circle
          cx="4"
          cy="4"
          r="2"></circle></svg
      >
    </a>
    <button
      class="share-buttons__btn"
      id="copy-link-btn"
      aria-label={t("post.copyLink")}
      title={t("post.copyLink")}
      data-url={fullUrl}
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
        ></path><path
          d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
        ></path></svg
      >
    </button>
  </div>
  <span class="share-buttons__copied" id="copied-feedback"
    >{t("post.linkCopied")}</span
  >
</div>

<style>
  .share-buttons {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .share-buttons__label {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-weight: 500;
  }
  .share-buttons__list {
    display: flex;
    gap: var(--space-2);
  }
  .share-buttons__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-sm);
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    text-decoration: none;
  }
  .share-buttons__btn:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px);
    background: var(--accent-glow);
  }
  .share-buttons__copied {
    font-size: var(--text-xs);
    color: var(--success);
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-out);
  }
  .share-buttons__copied.show {
    opacity: 1;
  }
</style>

<script>
  const copyBtn = document.getElementById("copy-link-btn");
  const feedback = document.getElementById("copied-feedback");
  copyBtn?.addEventListener("click", async () => {
    const url = (copyBtn as HTMLElement).dataset.url || window.location.href;
    await navigator.clipboard.writeText(url);
    feedback?.classList.add("show");
    setTimeout(() => feedback?.classList.remove("show"), 2000);
  });
</script>
