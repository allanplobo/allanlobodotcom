---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  readingTime?: string;
  slug: string;
}

const { title, description, date, tags, readingTime, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
---

<article class="post-card">
  <a href={`/blog/${slug}/`} class="post-card__link">
    <div class="post-card__header">
      <time class="post-card__date" datetime={date.toISOString()}>{formattedDate}</time>
      {readingTime && <span class="post-card__reading">{readingTime}</span>}
    </div>
    <h3 class="post-card__title">{title}</h3>
    <p class="post-card__description">{description}</p>
    <div class="post-card__tags">
      {tags.map((tag) => (
        <span class="post-card__tag">{tag}</span>
      ))}
    </div>
    <span class="post-card__cta">
      Ler artigo
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </span>
  </a>
</article>

<style>
.post-card{border-radius:var(--radius-md);border:1px solid var(--border);background:var(--bg-secondary);transition:all var(--duration-normal) var(--ease-out);overflow:hidden}
.post-card:hover{border-color:var(--accent);transform:translateY(-4px);box-shadow:0 8px 30px rgba(232,131,74,0.08),0 0 0 1px var(--accent)}
.post-card__link{display:block;padding:var(--space-6);text-decoration:none;color:inherit;height:100%}
.post-card__header{display:flex;align-items:center;gap:var(--space-3);margin-bottom:var(--space-3)}
.post-card__date{font-size:var(--text-xs);color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em}
.post-card__reading{font-size:var(--text-xs);color:var(--text-muted);display:flex;align-items:center;gap:var(--space-1)}
.post-card__reading::before{content:'·';margin-right:var(--space-1)}
.post-card__title{font-size:var(--text-xl);font-weight:700;color:var(--text-primary);margin-bottom:var(--space-2);line-height:1.3;transition:color var(--duration-fast) var(--ease-out)}
.post-card:hover .post-card__title{color:var(--accent)}
.post-card__description{font-size:var(--text-sm);color:var(--text-secondary);line-height:1.6;margin-bottom:var(--space-4);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.post-card__tags{display:flex;flex-wrap:wrap;gap:var(--space-2);margin-bottom:var(--space-4)}
.post-card__tag{font-size:var(--text-xs);color:var(--accent);background:var(--accent-glow);padding:2px 10px;border-radius:var(--radius-xl);font-weight:500}
.post-card__cta{display:inline-flex;align-items:center;gap:var(--space-2);font-size:var(--text-sm);color:var(--text-muted);font-weight:500;transition:all var(--duration-normal) var(--ease-out)}
.post-card:hover .post-card__cta{color:var(--accent)}
.post-card:hover .post-card__cta svg{transform:translateX(4px)}
.post-card__cta svg{transition:transform var(--duration-normal) var(--ease-out)}
</style>
