---
import { type Lang, defaultLang, getAlternateUrl } from "../i18n/i18n";

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  publishedDate?: string;
  modifiedDate?: string;
  lang?: Lang;
}

const lang = Astro.props.lang || defaultLang;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description,
  image = "/og-image.png",
  article = false,
  publishedDate,
  modifiedDate,
} = Astro.props;

const fullTitle =
  title === "Home"
    ? "Allan Lobo — " +
      (lang === "pt-br" ? "Desenvolvedor de Software" : "Software Developer")
    : `${title} | Allan Lobo`;

const ptUrl = new URL(getAlternateUrl(Astro.url.pathname, "pt-br"), Astro.site);
const enUrl = new URL(getAlternateUrl(Astro.url.pathname, "en"), Astro.site);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<link rel="canonical" href={canonicalURL} />

<link rel="alternate" hreflang="pt-BR" href={ptUrl} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="x-default" href={ptUrl} />

<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="author" content="Allan Lobo" />
<meta name="robots" content="index, follow" />

<meta property="og:type" content={article ? "article" : "website"} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.site)} />
<meta property="og:locale" content={lang === "pt-br" ? "pt_BR" : "en_US"} />
<meta property="og:site_name" content="Allan Lobo" />

{
  article && publishedDate && (
    <meta property="article:published_time" content={publishedDate} />
  )
}
{
  article && modifiedDate && (
    <meta property="article:modified_time" content={modifiedDate} />
  )
}
{article && <meta property="article:author" content="Allan Lobo" />}

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.site)} />

<script is:inline>
  (function () {
    try {
      if (localStorage.getItem("lang_preference_set") === "true") return;

      const path = window.location.pathname;
      const isEnPage = path.startsWith("/en/") || path === "/en";
      const browserLang = navigator.language || navigator.userLanguage;
      const isBrowserEn = browserLang.toLowerCase().startsWith("en");

      // Se o browser é inglês e está numa página PT, redireciona para EN
      if (isBrowserEn && !isEnPage) {
        window.location.replace("/en" + (path === "/" ? "" : path));
      }
      // Se o browser NÃO é inglês (ex: pt-BR) e está numa página EN, redireciona para PT
      else if (!isBrowserEn && isEnPage) {
        const newPath = path.replace(/^\/en/, "");
        window.location.replace(newPath === "" ? "/" : newPath);
      }
    } catch (e) {
      // Ignora erros de localStorage ou navegação
    }
  })();
</script>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
