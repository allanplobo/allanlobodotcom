---

---

<section class="hero" id="hero">
  <div class="hero__glow" id="hero-glow"></div>
  <div class="hero__content container">
    <p class="hero__greeting reveal" style="animation-delay:0.1s">
      <span class="hero__wave">👋</span> Olá, eu sou
    </p>
    <h1 class="hero__name reveal" style="animation-delay:0.2s">
      Allan <span class="hero__name-accent">Lobo</span>
    </h1>
    <div class="hero__typing-wrapper reveal" style="animation-delay:0.4s">
      <p class="hero__tagline">
        <span class="hero__prefix">&gt;</span>
        <span class="hero__typed" id="hero-typed"></span>
        <span class="hero__typed-cursor">|</span>
      </p>
    </div>
    <p class="hero__description reveal" style="animation-delay:0.6s">
      Desenvolvedor de Software na <strong>Luizalabs</strong>, criando soluções
      desde 2018. Apaixonado por tecnologia, boas práticas e compartilhar
      conhecimento.
    </p>
    <div class="hero__actions reveal" style="animation-delay:0.8s">
      <a href="/blog" class="hero__btn hero__btn--primary">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"
          ></path></svg
        >
        Ler o Blog
      </a>
      <button class="hero__btn hero__btn--secondary" id="hero-contact-trigger">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
          ></path></svg
        >
        Contato
      </button>
    </div>
    <div class="hero__stats reveal" style="animation-delay:1s">
      <div class="hero__stat">
        <span class="hero__stat-number" data-target="7">0</span><span
          class="hero__stat-plus">+</span
        >
        <span class="hero__stat-label">anos de experiência</span>
      </div>
      <div class="hero__stat-divider"></div>
      <div class="hero__stat">
        <span class="hero__stat-icon">🏢</span>
        <span class="hero__stat-label">Luizalabs</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
    padding: var(--space-16) 0 var(--space-20);
    margin-top: var(--header-height);
    overflow: hidden;
  }
  .hero__glow {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      var(--accent-glow-strong) 0%,
      transparent 70%
    );
    pointer-events: none;
    opacity: 0.5;
    z-index: 0;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    will-change: left, top;
    transition: opacity 0.3s ease-out;
  }
  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }
  .hero__greeting {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin-bottom: var(--space-2);
    animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  }
  .hero__wave {
    display: inline-block;
    animation: float 2s ease-in-out infinite;
  }
  .hero__name {
    font-size: var(--text-5xl);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: var(--space-4);
    animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  }
  .hero__name-accent {
    color: var(--accent);
    position: relative;
  }
  .hero__cursor {
    color: var(--accent);
    animation: blink 1s step-end infinite;
    font-weight: 400;
  }
  .hero__typing-wrapper {
    margin-bottom: var(--space-6);
    animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  }
  .hero__tagline {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--text-secondary);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
  }
  .hero__prefix {
    color: var(--accent);
    font-weight: 600;
  }
  .hero__typed {
    color: var(--text-primary);
  }
  .hero__typed-cursor {
    color: var(--accent);
    animation: blink 0.8s step-end infinite;
    font-weight: 300;
  }
  .hero__description {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-8);
    max-width: 580px;
    animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  }
  .hero__description strong {
    color: var(--accent);
  }
  .hero__actions {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
    animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  }
  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-xl);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out);
    text-decoration: none;
    border: none;
  }
  .hero__btn--primary {
    background: var(--accent);
    color: var(--bg-primary);
  }
  .hero__btn--primary:hover {
    background: var(--accent-light);
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
    color: var(--bg-primary);
  }
  .hero__btn--secondary {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border);
  }
  .hero__btn--secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }
  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  }
  .hero__stat {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .hero__stat-number {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .hero__stat-plus {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--accent);
  }
  .hero__stat-label {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .hero__stat-icon {
    font-size: var(--text-xl);
  }
  .hero__stat-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }
  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: var(--space-12) 0 var(--space-16);
    }
    .hero__name {
      font-size: var(--text-4xl);
    }
    .hero__actions {
      flex-direction: column;
    }
    .hero__btn {
      justify-content: center;
    }
    .hero__glow {
      width: 200px;
      height: 200px;
    }
  }
</style>

<script>
  // Typing effect
  const phrases = [
    "Desenvolvedor de Software",
    "Criando soluções digitais",
    "Engenheiro de Software",
    "Compartilhando conhecimento",
  ];

  const typedEl = document.getElementById("hero-typed");
  let phraseIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  function typeEffect() {
    if (!typedEl) return;
    const current = phrases[phraseIndex];

    if (isDeleting) {
      typedEl.textContent = current.substring(0, charIndex - 1);
      charIndex--;
    } else {
      typedEl.textContent = current.substring(0, charIndex + 1);
      charIndex++;
    }

    let delay = isDeleting ? 40 : 70;

    if (!isDeleting && charIndex === current.length) {
      delay = 2000;
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      phraseIndex = (phraseIndex + 1) % phrases.length;
      delay = 500;
    }

    setTimeout(typeEffect, delay);
  }

  typeEffect();

  // Glow follow mouse — uses left/top for precise cursor tracking
  const glow = document.getElementById("hero-glow");
  const hero = document.getElementById("hero");

  if (glow && hero) {
    // Use requestAnimationFrame for smooth performance
    let rafId: number | null = null;

    hero.addEventListener("mousemove", (e: MouseEvent) => {
      if (rafId) return; // throttle to rAF
      rafId = requestAnimationFrame(() => {
        const rect = hero.getBoundingClientRect();
        // Calculate cursor position relative to hero as percentage
        const xPercent = ((e.clientX - rect.left) / rect.width) * 100;
        const yPercent = ((e.clientY - rect.top) / rect.height) * 100;
        glow.style.left = `${xPercent}%`;
        glow.style.top = `${yPercent}%`;
        rafId = null;
      });
    });

    hero.addEventListener("mouseleave", () => {
      // Reset to center of hero
      glow.style.left = "50%";
      glow.style.top = "50%";
    });
  }

  // Number counter animation
  const counters = document.querySelectorAll(".hero__stat-number[data-target]");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target || "0");
          let current = 0;
          const step = () => {
            if (current < target) {
              current++;
              el.textContent = String(current);
              setTimeout(step, 100);
            }
          };
          step();
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.5 },
  );

  counters.forEach((c) => observer.observe(c));

  // Hero contact trigger
  const heroContactBtn = document.getElementById("hero-contact-trigger");
  heroContactBtn?.addEventListener("click", () => {
    document.getElementById("contact-overlay")?.classList.add("open");
    document.body.style.overflow = "hidden";
  });

  // Note: scroll reveal is handled globally by BaseLayout.astro
</script>
