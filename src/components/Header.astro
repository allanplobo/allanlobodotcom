---
import {
  type Lang,
  defaultLang,
  useTranslations,
  localePath,
  getAlternateUrl,
  languages,
} from "../i18n/i18n";

interface Props {
  lang?: Lang;
  alternateUrl?: string;
}

const lang = Astro.props.lang || defaultLang;
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
const alternateLang = lang === "pt-br" ? "en" : "pt-br";
const alternateUrl =
  Astro.props.alternateUrl ||
  getAlternateUrl(currentPath, alternateLang as Lang);
---

<header class="header" id="site-header">
  <nav class="header__nav container">
    <a
      href={localePath("/", lang)}
      class="header__logo"
      aria-label="Allan Lobo - Home"
    >
      <span class="header__logo-text"
        >allan<span class="header__logo-accent">lobo</span></span
      >
      <span class="header__logo-dot">.</span>
    </a>
    <div class="header__links">
      <a
        href={localePath("/blog", lang)}
        class:list={["header__link", { active: currentPath.includes("/blog") }]}
      >
        {t("nav.blog")}
      </a>
      <button
        class="header__contact-btn"
        id="contact-trigger"
        aria-label={t("nav.contact")}
      >
        {t("nav.contact")}
      </button>
      <a
        href={alternateUrl}
        class="header__lang-toggle"
        aria-label={`Switch to ${languages[alternateLang]}`}
        title={languages[alternateLang]}
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="12" r="10"></circle><line
            x1="2"
            y1="12"
            x2="22"
            y2="12"></line><path
            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
          ></path></svg
        >
        <span class="header__lang-label"
          >{alternateLang === "en" ? "EN" : "PT-BR"}</span
        >
      </a>
    </div>
    <button
      class="header__mobile-btn"
      id="mobile-menu-btn"
      aria-label="Menu"
      aria-expanded="false"
    >
      <span class="header__hamburger"></span>
    </button>
  </nav>
  <div class="header__mobile-menu" id="mobile-menu" aria-hidden="true">
    <a href={localePath("/blog", lang)} class="header__mobile-link"
      >{t("nav.blog")}</a
    >
    <button class="header__mobile-contact" id="contact-trigger-mobile"
      >{t("nav.contact")}</button
    >
    <a href={alternateUrl} class="header__mobile-lang">
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="12" cy="12" r="10"></circle><line
          x1="2"
          y1="12"
          x2="22"
          y2="12"></line><path
          d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
        ></path></svg
      >
      {languages[alternateLang]}
    </a>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--header-height);
    background: rgba(20, 20, 20, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition:
      border-color var(--duration-normal) var(--ease-out),
      background var(--duration-normal) var(--ease-out);
  }
  .header.scrolled {
    border-bottom-color: var(--border);
    background: rgba(20, 20, 20, 0.95);
  }
  .header__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  .header__logo {
    display: flex;
    align-items: center;
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: transform var(--duration-fast) var(--ease-spring);
  }
  .header__logo:hover {
    transform: scale(1.03);
    color: var(--text-primary);
  }
  .header__logo-accent {
    color: var(--accent);
  }
  .header__logo-dot {
    color: var(--accent);
    font-size: var(--text-2xl);
    line-height: 1;
    animation: textGlowPulse 3s ease-in-out infinite;
    display: inline-block;
  }
  .header__links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }
  .header__link {
    position: relative;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    padding: var(--space-2) 0;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .header__link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
    transition: width var(--duration-normal) var(--ease-out);
  }
  .header__link:hover {
    color: var(--text-primary);
  }
  .header__link:hover::after {
    width: 100%;
  }
  .header__link.active {
    color: var(--accent);
  }
  .header__link.active::after {
    width: 100%;
  }
  .header__contact-btn {
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-xl);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    transition: all var(--duration-normal) var(--ease-out);
  }
  .header__contact-btn:hover {
    background: var(--accent);
    color: var(--bg-primary);
    box-shadow: var(--shadow-glow);
    transform: translateY(-1px);
  }
  .header__lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-weight: 600;
    text-decoration: none;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    transition: all var(--duration-normal) var(--ease-out);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .header__lang-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .header__lang-label {
    line-height: 1;
  }
  .header__mobile-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    width: 40px;
    height: 40px;
    position: relative;
  }
  .header__hamburger,
  .header__hamburger::before,
  .header__hamburger::after {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: all var(--duration-normal) var(--ease-out);
    position: absolute;
    left: 8px;
  }
  .header__hamburger {
    top: 50%;
    transform: translateY(-50%);
  }
  .header__hamburger::before {
    content: "";
    top: -7px;
  }
  .header__hamburger::after {
    content: "";
    top: 7px;
  }
  .header__mobile-btn[aria-expanded="true"] .header__hamburger {
    background: transparent;
  }
  .header__mobile-btn[aria-expanded="true"] .header__hamburger::before {
    top: 0;
    transform: rotate(45deg);
    background: var(--accent);
  }
  .header__mobile-btn[aria-expanded="true"] .header__hamburger::after {
    top: 0;
    transform: rotate(-45deg);
    background: var(--accent);
  }
  .header__mobile-menu {
    display: none;
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    padding: var(--space-6);
    flex-direction: column;
    gap: var(--space-4);
    animation: fadeInUp var(--duration-normal) var(--ease-out);
  }
  .header__mobile-menu.open {
    display: flex;
  }
  .header__mobile-link {
    color: var(--text-primary);
    font-size: var(--text-lg);
    font-weight: 500;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .header__mobile-link:hover {
    color: var(--accent);
  }
  .header__mobile-contact {
    background: var(--accent);
    color: var(--bg-primary);
    border: none;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-xl);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    cursor: pointer;
    text-align: center;
    margin-top: var(--space-2);
    transition: all var(--duration-normal) var(--ease-out);
  }
  .header__mobile-contact:hover {
    background: var(--accent-light);
  }
  .header__mobile-lang {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-secondary);
    font-size: var(--text-base);
    text-decoration: none;
    padding: var(--space-3) 0;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .header__mobile-lang:hover {
    color: var(--accent);
  }
  @media (max-width: 768px) {
    .header__links {
      display: none;
    }
    .header__mobile-btn {
      display: block;
    }
  }
</style>

<script>
  const header = document.getElementById("site-header");
  window.addEventListener("scroll", () => {
    header?.classList.toggle("scrolled", window.scrollY > 20);
  });
  const mobileBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  mobileBtn?.addEventListener("click", () => {
    const expanded = mobileBtn.getAttribute("aria-expanded") === "true";
    mobileBtn.setAttribute("aria-expanded", String(!expanded));
    mobileMenu?.classList.toggle("open");
    mobileMenu?.setAttribute("aria-hidden", String(expanded));
  });

  // Save language preference on toggle click
  const langToggles = document.querySelectorAll(
    ".header__lang-toggle, .header__mobile-lang",
  );
  langToggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      // A URL contains the target language. We can just set a flag that the user has manually chosen a language
      // so the auto-redirect doesn't override them anymore.
      localStorage.setItem("lang_preference_set", "true");
    });
  });
</script>
