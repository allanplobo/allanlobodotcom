---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactModal from "../components/ContactModal.astro";
import { getLangFromUrl, type Lang } from "../i18n/i18n";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  publishedDate?: string;
  modifiedDate?: string;
  lang?: Lang;
  alternateUrl?: string;
}

const lang = Astro.props.lang || getLangFromUrl(Astro.url);
const htmlLang = lang === "pt-br" ? "pt-BR" : "en";
const props = Astro.props;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <BaseHead {...props} lang={lang} />
  </head>
  <body>
    <Header lang={lang} alternateUrl={props.alternateUrl} />
    <main id="main-content">
      <slot />
    </main>
    <Footer lang={lang} />
    <ContactModal lang={lang} />

    <script>
      const revealElements = document.querySelectorAll(
        ".reveal, .reveal-stagger",
      );
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1 },
      );

      revealElements.forEach((el) => revealObserver.observe(el));
    </script>

    <style>
      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      #main-content {
        flex: 1;
      }

      @media (max-width: 768px) {
        body {
          display: block;
        }
      }
    </style>
  </body>
</html>
